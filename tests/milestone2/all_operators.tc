int main() {
    int positive_division = 7 / 3;
    int positive_remainder = 7 % 3;
    int negative_division = -7 / 3;
    int negative_remainder = -7 % 3;

    return
        +5 == 5 &&
        !0 == 1 &&
        !3 == 0 &&
        positive_division == 2 &&
        positive_remainder == 1 &&
        negative_division == -2 &&
        negative_remainder == -1 &&
        1 < 2 &&
        2 > 1 &&
        2 <= 2 &&
        2 >= 2 &&
        2 == 2 &&
        2 != 3;
}
